<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主主题 (亮色) -->
    <style name="Theme.StockAnalyzer" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="toolbarBackground">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="cardViewStyle">@style/CardStyle</item>
        <item name="android:alertDialogTheme">@style/AlertDialogStyle</item>
    </style>

    <!-- 暗色主题 -->
    <style name="Theme.StockAnalyzer.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="toolbarBackground">@color/dark_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- AlertDialog 样式 -->
    <style name="AlertDialogStyle" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
    </style>

    <!-- 股票涨跌文字颜色 -->
    <style name="StockUpText">
        <item name="android:textColor">@color/stock_up</item>
    </style>

    <style name="StockDownText">
        <item name="android:textColor">@color/stock_down</item>
    </style>

    <!-- AI分析卡片样式 -->
    <style name="AIAnalysisCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">20dp</item>
        <item name="strokeColor">@color/ai_accent</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- 按钮样式 -->
    <style name="AnalysisButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">20dp</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
