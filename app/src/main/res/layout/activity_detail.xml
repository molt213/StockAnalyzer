<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/detail_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@color/text_on_primary"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/detail_swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 价格卡片 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/detail_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="?android:textColorPrimary" />

                                <TextView
                                    android:id="@+id/detail_symbol"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textColor="?android:textColorSecondary"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:id="@+id/detail_price"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="?android:textColorPrimary" />

                                <TextView
                                    android:id="@+id/detail_change"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="15sp"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                        <!-- 简要数据行 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/open"
                                    android:textSize="11sp"
                                    android:textColor="?android:textColorSecondary" />

                                <TextView
                                    android:id="@+id/detail_open"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/high"
                                    android:textSize="11sp"
                                    android:textColor="?android:textColorSecondary" />

                                <TextView
                                    android:id="@+id/detail_high"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/low"
                                    android:textSize="11sp"
                                    android:textColor="?android:textColorSecondary" />

                                <TextView
                                    android:id="@+id/detail_low"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="成交量"
                                    android:textSize="11sp"
                                    android:textColor="?android:textColorSecondary" />

                                <TextView
                                    android:id="@+id/detail_prev_close"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 自选股按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_watchlist"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:text="添加至自选股"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp"
                    app:icon="@drawable/ic_star_outline" />

                <!-- 图表 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="K线图"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/chip_group"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:singleSelection="true"
                                app:selectionRequired="true">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_1d"
                                    style="@style/Widget.Material3.Chip.Assist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5分K"
                                    android:textSize="12sp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_1w"
                                    style="@style/Widget.Material3.Chip.Assist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="60分K"
                                    android:textSize="12sp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_3m"
                                    style="@style/Widget.Material3.Chip.Assist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="日K"
                                    android:textSize="12sp"
                                    android:checked="true" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_1y"
                                    style="@style/Widget.Material3.Chip.Assist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="周K"
                                    android:textSize="12sp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chip_1m"
                                    style="@style/Widget.Material3.Chip.Assist"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="月K"
                                    android:textSize="12sp" />

                            </com.google.android.material.chip.ChipGroup>

                        </LinearLayout>

                        <com.github.mikephil.charting.charts.CandleStickChart
                            android:id="@+id/price_chart"
                            android:layout_width="match_parent"
                            android:layout_height="300dp"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- MACD 指标 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MACD (12, 26, 9)"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <com.github.mikephil.charting.charts.CombinedChart
                            android:id="@+id/macd_chart"
                            android:layout_width="match_parent"
                            android:layout_height="140dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- RSI 指标 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RSI (14)"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/rsi_chart"
                            android:layout_width="match_parent"
                            android:layout_height="100dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 公司信息 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/overview"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- 信息网格 -->
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="3">

                            <!-- 总市值 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/market_cap" android:textSize="12sp"
                                    android:textColor="?android:textColorSecondary" />
                                <TextView android:id="@+id/detail_market_cap"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <!-- 流通市值 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="流通市值" android:textSize="12sp"
                                    android:textColor="?android:textColorSecondary" />
                                <TextView android:id="@+id/detail_circulating_market_cap"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <!-- 市盈率 -->
                            <LinearLayout
                                android:id="@+id/detail_pe_container"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/pe_ratio" android:textSize="12sp"
                                    android:textColor="?android:textColorSecondary" />
                                <TextView android:id="@+id/detail_pe"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <!-- 换手率 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginBottom="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="换手率" android:textSize="12sp"
                                    android:textColor="?android:textColorSecondary" />
                                <TextView android:id="@+id/detail_turnover_rate"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <!-- 每股收益 -->
                            <LinearLayout
                                android:id="@+id/detail_eps_container"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/eps" android:textSize="12sp"
                                    android:textColor="?android:textColorSecondary" />
                                <TextView android:id="@+id/detail_eps"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <!-- 52周范围 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="@string/week_52_range" android:textSize="12sp"
                                    android:textColor="?android:textColorSecondary" />
                                <TextView android:id="@+id/detail_52w"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="2dp" />
                            </LinearLayout>

                        </GridLayout>

                        <TextView
                            android:id="@+id/detail_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="?android:textColorSecondary"
                            android:layout_marginTop="8dp"
                            android:maxLines="4"
                            android:ellipsize="end" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- 新闻 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/news"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/news_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <!-- 底部间距 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
